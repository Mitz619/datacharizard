# DataCharizard v2 — environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Claude ────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ── Discord ───────────────────────────────────────────
# Bot token: discord.com/developers → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here
# Guild (server) ID: right-click your server → Copy Server ID
DISCORD_GUILD_ID=123456789012345678
# Webhook URLs: channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_NEWS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_JOBS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_WEEKLY=https://discord.com/api/webhooks/...

# ── Football data ─────────────────────────────────────
# Free key: football-data.org/client/register (takes 2 min)
FOOTBALL_API_KEY=your_football_key_here

# ── Gmail (email backup — optional) ──────────────────
# App password: myaccount.google.com → Security → App passwords
GMAIL_SENDER=yourname@gmail.com
GMAIL_RECIPIENT=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── LinkedIn (optional — Apify is more reliable) ──────
# Free: apify.com → 5 free actor runs/month
APIFY_TOKEN=your_apify_token_here

